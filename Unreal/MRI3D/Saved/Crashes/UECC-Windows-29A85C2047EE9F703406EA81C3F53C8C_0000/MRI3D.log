import json
from pathlib import Path

color_map_path = r"C:\Users\Dipenshu\Desktop\Codes\MRI3D\results\UCSF_PDGM_0135_nifti\meshes\color_map.json"
tumor_map_path = r"C:\Users\Dipenshu\Desktop\Codes\MRI3D\results\UCSF_PDGM_0135_nifti\meshes\tumor_color_map.json"
mesh_content_path = "/Game/BrainViz/Meshes/"

with open(color_map_path) as f:
    color_map = json.load(f)

with open(tumor_map_path) as f:
    tumor_map = json.load(f)

asset_tools = unreal.AssetToolsHelpers.get_asset_tools()
editor_subsystem = unreal.EditorActorSubsystem()
mat_factory = unreal.MaterialInstanceConstantFactoryNew()

def create_colored_material(label_name, r, g, b):
    mat_path = f"/Game/BrainViz/Materials/M_{label_name}"
    mat = unreal.AssetTools.create_asset(
        asset_tools,
        f"M_{label_name}",
        "/Game/BrainViz/Materials",
        unreal.MaterialInstanceConstant,
        mat_factory
    )
    unreal.MaterialEditingLibrary.set_material_instance_vector_parameter_value(
        mat, "BaseColor", unreal.LinearColor(r, g, b, 1.0)
    )
    return mat

asset_registry = unreal.AssetRegistryHelpers.get_asset_registry()
assets = asset_registry.get_assets_by_path(mesh_content_path, recursive=False)

mesh_map = {}
for a in assets:
    mesh_map[a.asset_name] = a.get_asset()

spawned = 0

for label_id_str, info in color_map.items():
    mesh_name = Path(info["file"]).stem
    r, g, b = info["color_rgb_0_1"]

    mesh = mesh_map.get(mesh_name)
    if not mesh:
        continue

    actor = editor_subsystem.spawn_actor_from_class(
        unreal.StaticMeshActor,
        unreal.Vector(0, 0, 0),
        unreal.Rotator(0, 0, 0)
    )
    smc = actor.get_component_by_class(unreal.StaticMeshComponent)
    smc.set_static_mesh(mesh)
    actor.set_actor_label(f"Brain_{mesh_name}")

    mat = create_colored_material(mesh_name, r, g, b)
    smc.set_material(0, mat)
    spawned += 1

for name, info in tumor_map.items():
    mesh_name = Path(info["file"]).stem
    r, g, b = info["color_rgb_0_1"]

    mesh = mesh_map.get(mesh_name)
    if not mesh:
        continue

    actor = editor_subsystem.spawn_actor_from_class(
        unreal.StaticMeshActor,
        unreal.Vector(0, 0, 0),
        unreal.Rotator(0, 0, 0)
    )
    smc = actor.get_component_by_class(unreal.StaticMeshComponent)
    smc.set_static_mesh(mesh)
    actor.set_actor_label(f"Tumor_{name}")

    mat = create_colored_material(name, r, g, b)
    smc.set_material(0, mat)
    spawned += 1

print(f"Spawned {spawned} brain region actors into the scene")
